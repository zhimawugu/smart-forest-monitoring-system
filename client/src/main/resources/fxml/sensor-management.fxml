<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nci.forest.client.controller.SensorManagementController"
      spacing="10" style="-fx-padding: 10;">

    <!-- Title -->
    <Label text="Sensor Management" style="-fx-font-size: 18px; -fx-font-weight: bold;">
        <VBox.margin>
            <Insets bottom="10"/>
        </VBox.margin>
    </Label>

    <!-- Forest Selection and Add Button -->
    <HBox spacing="10">
        <Label text="Select Forest:" style="-fx-font-size: 12px;"/>
        <ComboBox fx:id="forestComboBox" prefWidth="200" onAction="#handleForestSelection"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addSensorButton" text="Add Sensor" onAction="#handleAddSensor"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 12px;"/>
        <Button fx:id="refreshButton" text="Refresh" onAction="#handleRefresh"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 12px;"/>
    </HBox>

    <!-- Sensors Table -->
    <Label text="Sensors in Selected Forest" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
    <TableView fx:id="sensorsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="120"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="100"/>
            <TableColumn fx:id="latitudeColumn" text="Latitude" prefWidth="100"/>
            <TableColumn fx:id="longitudeColumn" text="Longitude" prefWidth="100"/>
            <TableColumn fx:id="createdAtColumn" text="Created At" prefWidth="120"/>
            <TableColumn fx:id="actionColumn" text="Action" prefWidth="80"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <!-- Status Label -->
    <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #4CAF50; -fx-font-size: 11px;"/>
</VBox>

