<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         prefHeight="600.0" prefWidth="900.0">

    <!-- Forest Management Tab -->
    <Tab text="Forest Management" closable="false">
        <fx:include source="forest-management.fxml"/>
    </Tab>

    <!-- Sensor Management Tab -->
    <Tab text="Sensor Management" closable="false">
        <fx:include source="sensor-management.fxml"/>
    </Tab>

    <!-- Sensor Dashboard Tab -->
    <Tab text="Sensor Dashboard" closable="false">
        <fx:include source="sensor-dashboard.fxml"/>
    </Tab>

    <!-- Alert Management Tab -->
    <Tab text="Alert Management" closable="false">
        <fx:include source="alert-management.fxml"/>
    </Tab>

</TabPane>
