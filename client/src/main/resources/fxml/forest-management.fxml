<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nci.forest.client.controller.ForestManagementController"
      spacing="10" style="-fx-padding: 10;">

    <!-- Title -->
    <Label text="Forest Management" style="-fx-font-size: 18px; -fx-font-weight: bold;">
        <VBox.margin>
            <Insets bottom="10"/>
        </VBox.margin>
    </Label>

    <!-- Button Bar -->
    <HBox spacing="10">
        <Button fx:id="addButton" text="Add Forest" onAction="#handleAddForest"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 12px;">
            <HBox.margin>
                <Insets/>
            </HBox.margin>
        </Button>

        <Button fx:id="deleteButton" text="Delete Forest" onAction="#handleDeleteForest"
                style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 12px;">
        </Button>

        <Button fx:id="refreshButton" text="Refresh" onAction="#handleRefresh"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 12px;">
        </Button>
    </HBox>

    <!-- Forest Table -->
    <TableView fx:id="forestTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="150"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="150"/>
            <TableColumn fx:id="latitudeColumn" text="Latitude" prefWidth="120"/>
            <TableColumn fx:id="longitudeColumn" text="Longitude" prefWidth="120"/>
            <TableColumn fx:id="addressColumn" text="Address" prefWidth="250"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

</VBox>

